// SignNest - Railway Postgres + NextAuth
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth models
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // for credentials provider
  phone         String?
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// SignNest models
model Profile {
  id           String   @id
  fullName     String   @map("full_name")
  phone        String?
  email        String?
  role         String   @default("realtor") @map("role")
  companyName  String?  @map("company_name")
  kycStatus    String   @default("pending") @map("kyc_status")
  kycData      Json     @default("{}") @map("kyc_data")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user              User     @relation(fields: [id], references: [id], onDelete: Cascade)
  dealsCreated      Deal[]   @relation("DealCreator")
  partyMemberships  DealParty[]
  documentsUploaded Document[]
}

model Deal {
  id               String    @id @default(uuid())
  dealType         String    @map("deal_type")
  status           String    @default("draft")
  title            String
  propertyAddress  String    @map("property_address")
  propertyType     String?   @map("property_type")
  description      String?
  rentAmount       BigInt?   @map("rent_amount")
  rentPeriod       String?   @map("rent_period")
  rentStartDate    DateTime? @db.Date @map("rent_start_date")
  rentEndDate      DateTime? @db.Date @map("rent_end_date")
  cautionFee       BigInt?   @map("caution_fee")
  agencyFee        BigInt?   @map("agency_fee")
  legalFee         BigInt?   @map("legal_fee")
  salePrice        BigInt?   @map("sale_price")
  createdById      String    @map("created_by")
  completedAt      DateTime? @map("completed_at")
  cancelledAt      DateTime? @map("cancelled_at")
  cancelReason     String?   @map("cancel_reason")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  createdBy        Profile   @relation("DealCreator", fields: [createdById], references: [id], onDelete: Restrict)
  parties          DealParty[]
  documents        Document[]
  signatureRequests SignatureRequest[]
  auditLogs        AuditLog[]
  payments         Payment[]

  @@index([createdById])
  @@index([status])
}

model DealParty {
  id          String    @id @default(uuid())
  dealId      String    @map("deal_id")
  userId      String?   @map("user_id")
  role        String
  signOrder   Int?      @map("sign_order")
  status      String    @default("invited")
  inviteName  String    @map("invite_name")
  invitePhone String?   @map("invite_phone")
  inviteEmail String?   @map("invite_email")
  inviteToken String    @unique @default(cuid())
  invitedAt   DateTime  @default(now()) @map("invited_at")
  viewedAt    DateTime? @map("viewed_at")
  signedAt    DateTime? @map("signed_at")
  declinedAt  DateTime? @map("declined_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user        Profile? @relation(fields: [userId], references: [id], onDelete: SetNull)
  signatureRequests SignatureRequest[]

  @@unique([dealId, invitePhone])
  @@index([dealId])
  @@index([inviteToken])
}

model Document {
  id          String    @id @default(uuid())
  dealId      String    @map("deal_id")
  name        String
  filePath    String    @map("file_path")
  fileSize    BigInt?   @map("file_size")
  fileType    String?   @map("file_type")
  category    String    @default("other")
  permission  String    @default("view_only")
  watermark   Boolean   @default(true)
  uploadedById String   @map("uploaded_by")
  expiresAt   DateTime? @map("expires_at")
  isExecuted  Boolean   @default(false) @map("is_executed")
  version     Int       @default(1)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  uploadedBy  Profile  @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  signatureRequests SignatureRequest[]

  @@index([dealId])
}

model SignatureRequest {
  id             String    @id @default(uuid())
  dealId         String    @map("deal_id")
  documentId     String    @map("document_id")
  partyId        String    @map("party_id")
  otpPinId       String?   @map("otp_pin_id")
  otpExpiresAt   DateTime? @map("otp_expires_at")
  otpAttempts    Int       @default(0) @map("otp_attempts")
  otpVerifiedAt DateTime? @map("otp_verified_at")
  signatureData  String?   @map("signature_data")
  signedAt       DateTime? @map("signed_at")
  ipAddress      String?   @map("ip_address")
  userAgent      String?   @map("user_agent")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  deal          Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  party         DealParty @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@unique([documentId, partyId])
  @@index([dealId])
  @@index([partyId])
}

model AuditLog {
  id         String   @id @default(uuid())
  dealId     String?  @map("deal_id")
  action     String
  actorId    String?  @map("actor_id")
  actorName  String?  @map("actor_name")
  actorPhone String?  @map("actor_phone")
  metadata   Json     @default("{}")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  deal       Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@index([createdAt(sort: Desc)])
}

model Payment {
  id          String    @id @default(uuid())
  dealId      String    @map("deal_id")
  description String
  amount      BigInt
  currency    String    @default("NGN")
  status      String    @default("pending") // pending, paid, failed, refunded
  method      String?   // bank_transfer, cash, paystack, flutterwave
  reference   String?   // external payment reference
  paidBy      String?   @map("paid_by")
  paidAt      DateTime? @map("paid_at")
  receiptUrl  String?   @map("receipt_url")
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}
